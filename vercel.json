{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "(?!localhost|ucpmaroc\\.com|www\\.ucpmaroc\\.com).*"
        }
      ],
      "destination": "/api/edge-seo"
    },
    {
      "source": "/pro/:slug",
      "destination": "/api/edge-seo?slug=:slug"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}